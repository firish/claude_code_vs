{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/vs-permission-hook.ps1",
            "timeout": 86400
          }
        ]
      }
    ]
  }
}
