<Project Sdk="Microsoft.NET.Sdk">

  <!-- Minimal console project to verify getDiagnostics surfaces real C# errors.
       Program.cs contains a deliberate CS0029 (string -> int). Open this PROJECT in the
       experimental VS (File > Open > Project/Solution > diag-test.csproj) so Roslyn analyzes it
       and the Error List populates; then ask Claude "what errors do you see?". -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

</Project>
